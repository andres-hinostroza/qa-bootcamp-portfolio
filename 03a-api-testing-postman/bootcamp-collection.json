      "item": [
        {
          "name": "GET - Listar usuarios",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", function() {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El body contiene usuarios\", function() {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.be.an(\"array\");\r",
                  "    pm.expect(jsonData.length).to.be.above(0);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST - Crear post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 201\", function() {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El response contiene un id generado\", function() {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"id\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El título coincide con lo enviado\", function() {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.title).to.eql(\"Ejercicio QA\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"title\": \"Ejercicio QA\",\r\n  \"body\": \"Aprendiendo API Testing\",\r\n  \"userId\": 1\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            }
          },
          "response": []
        },
